<UserControl x:Class="KeyboardTracker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:KeyboardTracker.ViewModels"
             Background="#F0F2F5">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7C7C9A"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E2E4EA"/>
        <SolidColorBrush x:Key="Blue" Color="#427BD4"/>
        <SolidColorBrush x:Key="Green" Color="#34C759"/>
        <SolidColorBrush x:Key="Orange" Color="#FF9500"/>
        <SolidColorBrush x:Key="Purple" Color="#AF52DE"/>

        <Style x:Key="ModeBtn" TargetType="Button">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F0F0F5"/>
            <Setter Property="BorderBrush" Value="#D0D0DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#6B7280"/>
        </Style>
        <Style x:Key="ModeBtnActive" TargetType="Button" BasedOn="{StaticResource ModeBtn}">
            <Setter Property="Background" Value="#427BD4"/>
            <Setter Property="BorderBrush" Value="#427BD4"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,14"/>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Header -->
            <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="12,10"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Margin="0,0,0,12">
                <Grid>
                    <TextBlock Text="Activity Dashboard" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="◀" Width="32" Height="32" FontSize="12"
                                Command="{Binding PrevDayCommand}" Background="Transparent"
                                BorderThickness="0" Foreground="{StaticResource TextSecondary}" Cursor="Hand"/>
                        <TextBlock Text="{Binding SelectedDate, StringFormat={}{0:yyyy-MM-dd}}" FontSize="16"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center" Margin="8,0" MinWidth="120" TextAlignment="Center"/>
                        <Button Content="▶" Width="32" Height="32" FontSize="12"
                                Command="{Binding NextDayCommand}" Background="Transparent"
                                BorderThickness="0" Foreground="{StaticResource TextSecondary}" Cursor="Hand"/>
                    </StackPanel>
                    <Button Content="Today" Height="30" Padding="14,0" HorizontalAlignment="Right"
                            Command="{Binding TodayCommand}"
                            Foreground="White" Background="#427BD4" BorderThickness="0" Cursor="Hand"
                            FontSize="12" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Summary Cards -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="KEYS" Style="{StaticResource StatLabel}"/>
                        <TextBlock Text="{Binding TodayKeys}" Style="{StaticResource StatValue}" Foreground="#427BD4"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="CLICKS" Style="{StaticResource StatLabel}"/>
                        <TextBlock Text="{Binding TodayClicks}" Style="{StaticResource StatValue}" Foreground="#34C759"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="DISTANCE" Style="{StaticResource StatLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding TodayDistance}" Style="{StaticResource StatValue}" Foreground="#FF9500"/>
                            <TextBlock Text=" m" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="2,8,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="ACTIVE" Style="{StaticResource StatLabel}"/>
                        <TextBlock Text="{Binding TodayActive}" Style="{StaticResource StatValue}" Foreground="#AF52DE"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Keyboard + Mouse side by side -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Keyboard -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,5,0" MinWidth="700">
                    <StackPanel>
                        <TextBlock Text="Keyboard Heatmap" Style="{StaticResource CardTitle}"/>
                        <Grid x:Name="KeyboardGrid"/>
                        <Border Margin="0,8,0,0" Height="16" Width="280" CornerRadius="3" HorizontalAlignment="Left">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E3F2FD" Offset="0.0"/>
                                    <GradientStop Color="#90CAF9" Offset="0.25"/>
                                    <GradientStop Color="#42A5F5" Offset="0.5"/>
                                    <GradientStop Color="#1E88E5" Offset="0.75"/>
                                    <GradientStop Color="#0D47A1" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Grid Width="280" HorizontalAlignment="Left" Margin="0,2,0,0">
                            <TextBlock Text="less" FontSize="9" Foreground="#AAA" HorizontalAlignment="Left"/>
                            <TextBlock Text="more" FontSize="9" Foreground="#AAA" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mouse -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Mouse Activity" Style="{StaticResource CardTitle}"/>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Left" FontSize="13" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding LeftClicks}" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource Green}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Right" FontSize="13" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding RightClicks}" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource Orange}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Move" FontSize="13" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding TodayDistance}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Blue}"/>
                                <TextBlock Text=" m" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="2,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Chart -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Activity Chart" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                        <Border CornerRadius="6" Padding="2" Background="#F0F0F5" HorizontalAlignment="Right"
                                BorderBrush="#D0D0DA" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" x:Name="SegmentedControl" Loaded="OnSegmentedControlLoaded">
                                <Button Content="1h"  Tag="0" Click="OnChartModeClick" Cursor="Hand"/>
                                <Button Content="1d"  Tag="1" Click="OnChartModeClick" Cursor="Hand"/>
                                <Button Content="7d"  Tag="2" Click="OnChartModeClick" Cursor="Hand"/>
                                <Button Content="1y"  Tag="3" Click="OnChartModeClick" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <TextBlock Text="No data yet" Foreground="{StaticResource TextSecondary}"
                               FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,0"
                               Visibility="{Binding HasActivity, Converter={x:Static vm:InverseBoolConverter.Instance}}"/>
                    <lvc:CartesianChart
                                        Series="{Binding ActivitySeries}"
                                        XAxes="{Binding ActivityXAxes}" YAxes="{Binding ActivityYAxes}"
                                        Height="220"
                                        Visibility="{Binding HasActivity, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
                </StackPanel>
            </Border>

            <!-- Daily Summary -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Daily Summary" Style="{StaticResource CardTitle}"/>
                    <DataGrid ItemsSource="{Binding DailySummaries}" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0" HeadersVisibility="Column">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FAFAFC"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                            <DataGridTextColumn Header="Keys" Binding="{Binding TotalKeyPresses, StringFormat={}{0:N0}}" Width="*"/>
                            <DataGridTextColumn Header="Clicks" Binding="{Binding TotalMouseClicks, StringFormat={}{0:N0}}" Width="*"/>
                            <DataGridTextColumn Header="Distance (m)" Binding="{Binding TotalMouseDistance, StringFormat={}{0:F1}}" Width="*"/>
                            <DataGridTextColumn Header="Active" Binding="{Binding ActiveTimeFormatted}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
